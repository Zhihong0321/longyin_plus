{
  "name": "longyin-plus-electron",
  "author": "Zhihong0321",
  "private": true,
  "version": "0.1.10",
  "description": "龙胤立志传 Pro Max 的便携式 Electron 启动器与更新器",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n MAIN,RENDERER,ELECTRON \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/main.js dist/renderer/index.html && electron .",
    "build": "npm run build:main && npm run build:renderer && set CSC_IDENTITY_AUTO_DISCOVERY=false&&electron-builder --win zip && npm run build:manifest",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:manifest": "node scripts/generate-update-manifest.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "start": "electron ."
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zhihong.longyinplus",
    "productName": "龙胤立志传 Pro Max",
    "executableName": "LongYinProMax",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "payload"
      },
      {
        "from": "scripts/apply-ota-update.cmd",
        "to": "updater/apply-ota-update.cmd"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "LongYinProMaxApp-${version}-${os}-${arch}.${ext}"
    }
  }
}
